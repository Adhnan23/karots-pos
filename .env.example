# ===========================================================================
# DEVELOPER MACHINE (.env in the repo root)
#
# This is the env for working ON the POS. What a SHOP gets is different — see
# .env.production.example, which is also what `make bootstrap` writes into
# dist/.env.sample.
#
# The one line that must never appear in a shop's .env is POS_SUPPORT_SECRET at
# the bottom: it is the master key every shop's support PIN is derived from.
# ===========================================================================
APP_ENV=development
# Quote the value if it contains special characters such as & (e.g. a hosted
# Postgres like Neon: ...?sslmode=require&channel_binding=require). The make
# targets source this file, and an unquoted & makes the shell drop the value.
DATABASE_URL="postgres://pos_user:pos_password@localhost:5432/pos_db?sslmode=disable"
SERVER_PORT=3000
# Must be at least 32 characters.
JWT_SECRET=dev-secret-change-me-0123456789abcdef
# Access token TTL. For the cookie-based UI this doubles as the session length,
# so a shift-length value (e.g. 12h) is convenient. API clients refresh tokens.
JWT_EXPIRES_IN=12h
JWT_REFRESH_EXPIRES_IN=168h
# The address typed into the browser (this server's own). One entry however many
# tills there are — see .env.production.example.
CORS_ORIGINS=http://localhost:3000

# auto | always | never — see .env.production.example. Auto follows the actual
# connection, which is right for both a LAN shop and an HTTPS install.
COOKIE_SECURE=auto
# Printers are chosen in Admin → Settings → Printers & Labels (detected from the
# OS, or a tcp://IP:9100 network address) — no env var needed. See PRINTING.md.
# Automatic time-based backups. Set BACKUP_DIR to a writable path to enable the
# in-process backup scheduler (same pure-Go snapshot as the Settings → Backup
# button); leave it empty to disable (manual backup/restore still works). Point
# it at a mounted volume or an off-site-synced path — a backup on the database's
# own disk does not survive disk/host loss. Defaults: every 6h, keep the last 28.
BACKUP_DIR=
BACKUP_INTERVAL=6h
BACKUP_KEEP=28


# Master key for deriving each shop's support PIN. Used at two moments, both on
# THIS machine: `make bootstrap` (bakes the derived PIN into a shop's binary) and
# `make support-pin ID=...` (recomputes it when a shop calls). It is never
# compiled into a shipped binary and never belongs in a shop's .env.
#
# Back it up. Lose it and you cannot derive the PIN for any shop already in the
# field — the only way back in then is POS_SYSTEM_PIN in that shop's own .env.
POS_SUPPORT_SECRET=
