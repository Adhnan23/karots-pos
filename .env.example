APP_ENV=development
# Quote the value if it contains special characters such as & (e.g. a hosted
# Postgres like Neon: ...?sslmode=require&channel_binding=require). The make
# targets source this file, and an unquoted & makes the shell drop the value.
DATABASE_URL="postgres://pos_user:pos_password@localhost:5432/pos_db?sslmode=disable"
SERVER_PORT=3000
# Must be at least 32 characters.
JWT_SECRET=dev-secret-change-me-0123456789abcdef
# Access token TTL. For the cookie-based UI this doubles as the session length,
# so a shift-length value (e.g. 12h) is convenient. API clients refresh tokens.
JWT_EXPIRES_IN=12h
JWT_REFRESH_EXPIRES_IN=168h
CORS_ORIGINS=http://localhost:3000
# Printers are chosen in Admin → Settings → Printers & Labels (detected from the
# OS, or a tcp://IP:9100 network address) — no env var needed. See PRINTING.md.
# Automatic time-based backups. Set BACKUP_DIR to a writable path to enable the
# in-process backup scheduler (same pure-Go snapshot as the Settings → Backup
# button); leave it empty to disable (manual backup/restore still works). Point
# it at a mounted volume or an off-site-synced path — a backup on the database's
# own disk does not survive disk/host loss. Defaults: every 6h, keep the last 28.
BACKUP_DIR=
BACKUP_INTERVAL=6h
BACKUP_KEEP=28

# >>> DEV ONLY — stripped from the .env.sample the bootstrapper ships to a shop.
# POS_SUPPORT_SECRET is YOUR master key for deriving each shop's support PIN. It
# belongs on the machine that BUILDS shop binaries and nowhere else: the
# bootstrapper reads it from the environment and bakes it into the binary with
# -ldflags, so the running server never reads it and a shop owner reading their
# own .env learns nothing. Put it in a shop's .env and you have handed them (and
# anyone with access to their machine) the key to every shop you ship.
#
#   POS_SUPPORT_SECRET=... make bootstrap
#   ./karots-pos -support-pin <install-id>     # id is on their login screen
#
# Build without it and every binary falls back to one shared PIN; the server
# warns about that on each boot.
# POS_SUPPORT_SECRET=
# <<< DEV ONLY
