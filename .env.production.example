# ===========================================================================
# A SHOP'S .env  —  goes next to the binary, and is read automatically
#
#   /opt/karots-pos/
#     karots-pos
#     .env          ← this file, renamed
#
# The server reads it from beside the executable, so it does not matter which
# folder the shop launches from and nothing has to be exported first.
#
# `make bootstrap` writes this into dist/.env.sample. Fill it in per shop.
#
# NOTE: POS_SUPPORT_SECRET must NEVER appear here. That is the developer's
# master key; this shop's support PIN is already compiled into its own binary.
# ===========================================================================

# Turns on production behaviour, including secure cookies (serve over HTTPS or
# the login cookie will not stick) and refusing a -reset without -force.
APP_ENV=production

# The shop's own database. Quote it if it contains & or other shell characters.
DATABASE_URL="postgres://pos_user:CHANGE_ME@localhost:5432/pos_db?sslmode=disable"

SERVER_PORT=3000

# MUST be at least 32 characters and MUST be different for every shop — it signs
# the login cookies. Generate one per install, e.g.
#   openssl rand -base64 48
JWT_SECRET=CHANGE_ME_AT_LEAST_32_CHARACTERS_LONG

# How long a signed-in session lasts. 12h matches a working day so a cashier is
# not logged out mid-shift.
JWT_EXPIRES_IN=12h
JWT_REFRESH_EXPIRES_IN=168h

# Where the browser may talk to the server from. Add the till's address if the
# shop reaches it over the network rather than on the same machine.
CORS_ORIGINS=http://localhost:3000

# Automatic backups. Point BACKUP_DIR at a path that is NOT on the database's own
# disk — a backup that dies with the disk it was protecting is not a backup. A
# USB drive, a mapped network share, or a folder synced off-site all work.
# Leave empty to disable the scheduler (manual backup/restore still works).
BACKUP_DIR=./backups
BACKUP_INTERVAL=6h
BACKUP_KEEP=28

# Emergency access only. Setting this overrides the support PIN compiled into
# this shop's binary — the way back in if the developer's master key is ever
# lost. Leave it commented out in normal operation.
# POS_SYSTEM_PIN=
